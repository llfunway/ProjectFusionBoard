// 计算标准化残差
float innovation_std = sqrtf(denom * R_adaptive);  // 利用上面的自适应 R
float std_residual = fabsf(error) / (innovation_std + 1.0f);

if (std_residual > 3.0f) {
    // 完全拒绝：ADC 毛刺或 I2C 故障
